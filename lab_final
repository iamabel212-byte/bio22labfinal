};
const mStateG = {};

function buildMatchG(key) {
  const data = matchDataG[key];
  const wrap = document.getElementById(key+'-left-wrap');
  wrap.innerHTML = '';
  mStateG[key] = { selected: null, matched: 0, total: data.keys.length };
  document.getElementById(key+'-score').textContent = '0';
  document.getElementById(key+'-complete').classList.remove('show');

  const shuffledK = shuffle(data.keys);
  const shuffledV = shuffle(data.keys.map(k => data.pairs[k]));

  const leftCol = document.createElement('div');
  leftCol.className = 'match-col';
  const rightCol = document.createElement('div');
  rightCol.className = 'match-col';

  shuffledK.forEach(k => {
    const el = document.createElement('div');
    el.className = 'match-item';
    el.textContent = k;
    el.dataset.side = 'left'; el.dataset.val = k; el.dataset.key = key;
    el.onclick = () => handleMatchG(el);
    leftCol.appendChild(el);
  });
  shuffledV.forEach(v => {
    const el = document.createElement('div');
    el.className = 'match-item';
    el.textContent = v;
    el.dataset.side = 'right'; el.dataset.val = v; el.dataset.key = key;
    el.onclick = () => handleMatchG(el);
    rightCol.appendChild(el);
  });
  wrap.appendChild(leftCol);
  wrap.appendChild(rightCol);
}

function handleMatchG(el) {
  const key = el.dataset.key;
  const st = mStateG[key];
  const data = matchDataG[key];
  if (el.classList.contains('matched')) return;
  if (!st.selected) { el.classList.add('selected'); st.selected = el; return; }
  if (st.selected === el) { el.classList.remove('selected'); st.selected = null; return; }
  if (st.selected.dataset.side === el.dataset.side) {
    st.selected.classList.remove('selected'); el.classList.add('selected'); st.selected = el; return;
  }
  const leftEl  = st.selected.dataset.side==='left'  ? st.selected : el;
  const rightEl = st.selected.dataset.side==='right' ? st.selected : el;
  const ok = data.pairs[leftEl.dataset.val] === rightEl.dataset.val;
  st.selected = null;
  leftEl.classList.remove('selected'); rightEl.classList.remove('selected');
  if (ok) {
    leftEl.classList.add('matched'); rightEl.classList.add('matched');
    st.matched++;
    document.getElementById(key+'-score').textContent = st.matched;
    if (st.matched === st.total) document.getElementById(key+'-complete').classList.add('show');
  } else {
    leftEl.classList.add('wrong-flash'); rightEl.classList.add('wrong-flash');
    setTimeout(() => { leftEl.classList.remove('wrong-flash'); rightEl.classList.remove('wrong-flash'); }, 700);
  }
}

buildMatchG('mmtest');
buildMatchG('mmsugar');
buildMatchG('mmemg');
buildMatchG('mmtools');
buildMatchG('mmthyroid');
buildMatchG('mmdna');
buildMatchG('mmdnabp');
buildMatchG('mmrnabp');
buildMatchG('mmwbc');
buildMatchG('mmreflex');
buildMatchG('mmns');
buildMatchG('mmbp');
</script>
