          <tr style="border-top:1px solid #2a2d3a;"><td style="padding:10px 14px;color:#ff6b6b;">No clump</td><td style="padding:10px 14px;color:#ff6b6b;">No clump</td><td style="padding:10px 14px;color:#ff6b6b;">No clump</td><td style="padding:10px 14px;font-weight:700;color:#e0e4f0;">O−</td></tr>
        </tbody>
      </table>
    </div>
  </div><!-- end panel-blood -->

</div><!-- end container -->
<script>
// EXAM
let score = 0, answered = 0;
const totalInteractive = 9;
const answered_ids = {};

function updateScore() {
  const pct = Math.round((score / totalInteractive) * 100);
  document.getElementById('scoreInner').textContent = score;
  document.getElementById('scoreLabel').textContent = answered + ' / ' + totalInteractive;
  document.getElementById('scoreCircle').style.setProperty('--pct', pct);
}

function choose(btn, id, correct) {
  if (answered_ids[id]) return;
  answered_ids[id] = true; answered++;
  const siblings = btn.closest('.btn-row').querySelectorAll('.opt-btn');
  siblings.forEach(b => b.classList.add('disabled'));
  const fb = document.getElementById(id + '-fb');
  const card = document.getElementById('card-' + id);
  if (correct) {
    btn.classList.add('correct'); score++;
    if (fb) fb.className = 'feedback right show';
    if (card) card.classList.add('answered-correct');
  } else {
    btn.classList.add('wrong');
    siblings.forEach(b => { if ((b.getAttribute('onclick')||'').includes(',true)')) b.classList.add('correct'); });
    if (fb) fb.className = 'feedback wrong-f show';
    if (card) card.classList.add('answered-wrong');
  }
  updateScore();
}

function toggleAnswer(id, btn) {
  const box = document.getElementById(id);
  box.classList.toggle('show');
  btn.textContent = box.classList.contains('show') ? 'Hide answer' : 'Show answer';
}

function toggleAP(btn) {
  const w = document.getElementById('apWrap');
  w.classList.toggle('show');
  btn.textContent = w.classList.contains('show') ? 'Hide diagram' : 'Show diagram';
}

// TABS
const topKeys = ['exam','gi','labs','blood','tools'];
const subKeys = ['tips','flash','msym','marea','mtreat'];

function switchTop(id) {
  document.querySelectorAll('.top-tab').forEach((t,i) => t.classList.toggle('active', topKeys[i]===id));
  document.querySelectorAll('.top-panel').forEach(p => p.classList.toggle('active', p.id==='panel-'+id));
}

function resetExam() {
  score = 0; answered = 0;
  Object.keys(answered_ids).forEach(k => delete answered_ids[k]);
  updateScore();
  document.querySelectorAll('.q-card').forEach(c => c.classList.remove('answered-correct','answered-wrong'));
  document.querySelectorAll('.opt-btn').forEach(b => b.classList.remove('correct','wrong','disabled'));
  document.querySelectorAll('.feedback').forEach(f => { f.className = 'feedback'; });
  document.querySelectorAll('.answer-box').forEach(b => b.classList.remove('show'));
  document.querySelectorAll('.reveal-btn').forEach(b => {
    if (b.textContent.includes('Hide')) b.textContent = b.textContent.replace('Hide','Show');
  });
  const ap = document.getElementById('apWrap');
  if (ap) { ap.classList.remove('show'); ap.previousElementSibling.textContent = 'Show diagram'; }
}

// BLOOD TYPING PRACTICE
const btTypes = [
  { type:'A+',  a:true,  b:false, rh:true  },
  { type:'A-',  a:true,  b:false, rh:false },
  { type:'B+',  a:false, b:true,  rh:true  },
  { type:'B-',  a:false, b:true,  rh:false },
  { type:'AB+', a:true,  b:true,  rh:true  },
  { type:'AB-', a:true,  b:true,  rh:false },
  { type:'O+',  a:false, b:false, rh:true  },
  { type:'O-',  a:false, b:false, rh:false },
];
let btCurrent = null, btStreak = 0, btBest = 0, btPatientNum = 0, btAnswered = false;

function btNext() {
  btAnswered = false;
  btPatientNum++;
  btCurrent = btTypes[Math.floor(Math.random() * btTypes.length)];
  document.getElementById('bt-patient-label').textContent = 'Patient ' + btPatientNum;
  const clump = v => v
    ? '<span style="color:#3ecf8e">Clumps \u2713<\/span>'
    : '<span style="color:#ff6b6b">No clump \u2717<\/span>';
  document.getElementById('bt-a').innerHTML  = clump(btCurrent.a);
  document.getElementById('bt-b').innerHTML  = clump(btCurrent.b);
  document.getElementById('bt-rh').innerHTML = clump(btCurrent.rh);
  const fb = document.getElementById('bt-practice-fb');
  fb.className = 'feedback';
  document.querySelectorAll('#bt-answer-row .opt-btn').forEach(b => b.classList.remove('correct','wrong','disabled'));
}

function btGuess(guess) {
  if (btAnswered) return;
  btAnswered = true;
  const btns = document.querySelectorAll('#bt-answer-row .opt-btn');
  btns.forEach(b => {
    b.classList.add('disabled');
    const label = b.textContent.replace('−','-');
    if (label === btCurrent.type) b.classList.add('correct');
    else if (label === guess) b.classList.add('wrong');
  });
  const fb = document.getElementById('bt-practice-fb');
  if (guess === btCurrent.type) {
    btStreak++;
    if (btStreak > btBest) btBest = btStreak;
    fb.className = 'feedback right show';
    fb.textContent = '✓ Correct! ' + btCurrent.type + ' — tap "Next patient" for another.';
  } else {
    btStreak = 0;
    fb.className = 'feedback wrong-f show';
    fb.innerHTML = '✗ Not quite — the correct answer is <strong>' + btCurrent.type + '<\/strong>. ' +
      (btCurrent.a ? 'Anti-A clumps → A antigen present. ' : 'Anti-A no clump → no A antigen. ') +
      (btCurrent.b ? 'Anti-B clumps → B antigen present. ' : 'Anti-B no clump → no B antigen. ') +
      (btCurrent.rh ? 'Anti-Rh clumps → Rh positive.' : 'Anti-Rh no clump → Rh negative.');
  }
  document.getElementById('bt-streak').textContent = btStreak;
  document.getElementById('bt-best').textContent = btBest;
}

// Init blood typing on load
btNext();

function switchSub(id) {
  document.querySelectorAll('.sub-tab').forEach((t,i) => t.classList.toggle('active', subKeys[i]===id));
  document.querySelectorAll('.sub-panel').forEach(p => p.classList.toggle('active', p.id==='sub-'+id));
}

const subKeys2 = ['macro','osmo','reflex','urine','emg','thyroid','dna','wbclab','neurosim','bp'];
function switchSub2(id) {
  document.querySelectorAll('.sub-tab2').forEach((t,i) => t.classList.toggle('active', subKeys2[i]===id));
  document.querySelectorAll('.sub-panel2').forEach(p => p.classList.toggle('active', p.id==='sub2-'+id));
}

// MATCHING
const diseases = ['GERD','IBS','Gallstones','Gastric Ulcers'];
const matchData = {
  msym: {
    'GERD':           'Heartburn, acid regurgitation, chest pain',
    'IBS':            'Cramping, bloating, alternating constipation and diarrhea',
    'Gallstones':     'Sharp RUQ pain after eating fatty food, nausea',
    'Gastric Ulcers': 'Burning stomach pain worse on an empty stomach'
  },
  marea: {
    'GERD':           'Esophagus / lower esophageal sphincter',
    'IBS':            'Large intestine (colon)',
    'Gallstones':     'Gallbladder',
    'Gastric Ulcers': 'Stomach lining (mucosa)'
  },
  mtreat: {
    'GERD':           'PPIs (omeprazole), antacids, lifestyle changes',
    'IBS':            'Low-FODMAP diet, stress management, antispasmodics',
    'Gallstones':     'Cholecystectomy (surgical removal)',
    'Gastric Ulcers': 'PPIs + antibiotics (H. pylori); avoid NSAIDs'
  }
};

const mState = {};

function shuffle(a) {
  const arr = [...a];
  for (let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}
  return arr;
}

function buildMatch(key) {
  const wrap = document.getElementById(key+'-left-wrap');
  wrap.innerHTML = '';
  mState[key] = { selected: null, matched: 0 };
  document.getElementById(key+'-score').textContent = '0';
  document.getElementById(key+'-complete').classList.remove('show');

  const shuffledD = shuffle(diseases);
  const shuffledA = shuffle(diseases.map(d => matchData[key][d]));

  const leftCol = document.createElement('div');
  leftCol.className = 'match-col';
  const rightCol = document.createElement('div');
  rightCol.className = 'match-col';

  shuffledD.forEach(d => {
    const el = document.createElement('div');
    el.className = 'match-item';
    el.textContent = d;
    el.dataset.side = 'left';
    el.dataset.val = d;
    el.dataset.key = key;
    el.onclick = () => handleMatch(el);
    leftCol.appendChild(el);
  });

  shuffledA.forEach(a => {
    const el = document.createElement('div');
    el.className = 'match-item';
    el.textContent = a;
    el.dataset.side = 'right';
    el.dataset.val = a;
    el.dataset.key = key;
    el.onclick = () => handleMatch(el);
    rightCol.appendChild(el);
  });

  wrap.appendChild(leftCol);
  wrap.appendChild(rightCol);
}

function handleMatch(el) {
  const key = el.dataset.key;
  const st = mState[key];
  if (el.classList.contains('matched')) return;

  if (!st.selected) {
    el.classList.add('selected');
    st.selected = el;
    return;
  }
  if (st.selected === el) {
    el.classList.remove('selected');
    st.selected = null;
    return;
  }
  if (st.selected.dataset.side === el.dataset.side) {
    st.selected.classList.remove('selected');
    el.classList.add('selected');
    st.selected = el;
    return;
  }

  const leftEl  = st.selected.dataset.side==='left'  ? st.selected : el;
  const rightEl = st.selected.dataset.side==='right' ? st.selected : el;
  const disease = leftEl.dataset.val;
  const answer  = rightEl.dataset.val;
  const ok = matchData[key][disease] === answer;

  st.selected = null;
  leftEl.classList.remove('selected');
  rightEl.classList.remove('selected');

  if (ok) {
    leftEl.classList.add('matched');
    rightEl.classList.add('matched');
    st.matched++;
    document.getElementById(key+'-score').textContent = st.matched;
    if (st.matched === 4) document.getElementById(key+'-complete').classList.add('show');
  } else {
    leftEl.classList.add('wrong-flash');
    rightEl.classList.add('wrong-flash');
    setTimeout(() => { leftEl.classList.remove('wrong-flash'); rightEl.classList.remove('wrong-flash'); }, 700);
  }
}

buildMatch('msym');
buildMatch('marea');
buildMatch('mtreat');

// GENERIC MATCHING ENGINE (macromolecules)
const matchDataG = {
  mmtest: {
    keys: ["Benedict's reagent", "Iodine", "Biuret reagent", "Paper test"],
    pairs: {
      "Benedict's reagent": "Simple sugars — turns yellow, orange, or red",
      "Iodine":             "Starch — turns dark blue/black",
      "Biuret reagent":     "Protein — turns lavender or violet",
      "Paper test":         "Lipids — leaves translucent spot when dry"
    }
  },
  mmsugar: {
    keys: ["Monosaccharide", "Disaccharide", "Polysaccharide", "Hydrolysis"],
    pairs: {
      "Monosaccharide":  "Single sugar molecule (e.g. glucose, fructose)",
      "Disaccharide":    "Two sugars bonded together (e.g. sucrose, lactose)",
      "Polysaccharide":  "3+ sugars bonded together (e.g. starch, glycogen)",
      "Hydrolysis":      "Breaking sugar bonds using water and enzymes"
